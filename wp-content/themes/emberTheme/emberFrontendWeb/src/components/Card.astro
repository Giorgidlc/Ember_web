---
import Button from "@components/Button.astro";

interface CardProps {
  id: string;
  title: string;
  description: string;
  buttonText: string;
  url?: string;
  target?: string
  appearance?: "red" | "yellow" | "orange" | "transparent";
}

const { id, title, description, buttonText, url, target, appearance } =
  Astro.props as CardProps;
---

<div 
  id={id}
  class:list={["card", `card--${appearance}`]}
>
  <h3>{title}</h3>
  <span set:html={description}/>
  <Button 
    buttonText={buttonText} 
    href={url} 
    target={target} 
    variant="secondary"
  />
</div> 


<style>
  .card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: .9rem;
    border-radius: 50px 0px 50px 0px;
    padding: 2rem;
    background-color: var(--color-accent);
    min-block-size: 280px;

    & h3 {
      font-size: var(--fontSize-large);
      color: var(--color-base);
      text-transform: uppercase;
    }

    & span {
      font-size: var(--fontSize-medium);
      color: var(--color-base);
      font-weight: 100;
    }
  }
</style>