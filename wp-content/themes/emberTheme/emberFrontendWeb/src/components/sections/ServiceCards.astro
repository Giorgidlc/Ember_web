---
import Card from "@/components/Card.astro";
import Button from "../Button.astro";

interface CardData {
  id: number | string;
  title: string;
  description: string;
  buttonText: string;
  url?: string;
  target?: string;
}


const { services, features } = Astro.props as { services: CardData[]; features?: { title: string; buttonText: string }[];};
---

<article>
  <section class="inner">
    {
      services.map((service) => (
        <Card
          id={service.id}
          title={service.title}
          description={service.description}
          buttonText={service.buttonText}
        />
      ))
    }
  </section>
<!--   <div class="inner">
    <h2>{features[0].title}</h2>
    <Button buttonText={features[0].buttonText} />
  </div> -->
</article>

<style>
  article {
    display: flex;
    flex-direction: column;
    gap: var(--space-block);
  }

  section {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 2rem;
  }

    div {
    display: flex;
    flex-direction: column;
    gap: 2rem;

    h2 {
      font-size: var(--fontSize-x-large);
      color: var(--color-contrast-2);
      max-inline-size: 16ch;
    }
  }

    @media (width < 480px) {
      section { 
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
      }
    }
</style>
